# 复制为 .env.development 本地使用
# 开发时请求 /api → vite.config 代理到后端（默认 http://127.0.0.1:8080）
VITE_API_BASE_URL=
VITE_API_PREFIX=/api/v1

# true：不请求后端，使用 src/api/backendMock.ts
# false：走真实接口（需后端按 src/types/api.ts 契约实现）
VITE_USE_MOCK=true

# 实时联动模式：auto | push | poll
VITE_SECURITY_REALTIME_MODE=auto

# 轮询模式下的间隔毫秒
VITE_SECURITY_POLL_INTERVAL_MS=5000
